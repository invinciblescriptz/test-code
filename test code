local function formatNumber(num)
    return tostring(num):reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
end

local function updateKills()
    local formatted = formatNumber(killsValue.Value)
    KillsLabel.Text = formatted
    local tween = game:GetService("TweenService"):Create(KillsLabel, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {TextTransparency = 0.5})
    tween:Play()
    tween.Completed:Connect(function()
        local tween2 = game:GetService("TweenService"):Create(KillsLabel, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0})
        tween2:Play()
    end)
end

killsValue.Changed:Connect(updateKills)
