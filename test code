end

-- Get stat value
local function GetPlayerStatValue(plr, statNames)
    if not plr then return nil end
    if type(statNames) == "string" then statNames = {statNames} end

    for _, name in ipairs(statNames) do
        local val = plr:GetAttribute(name)
        if val ~= nil then return tonumber(val) end
    end

    local stats = plr:FindFirstChild("leaderstats")
    if stats then
        for _, name in ipairs(statNames) do
            local v = stats:FindFirstChild(name)
            if v and v:IsA("ValueBase") then
                return tonumber(v.Value)
            end
        end
    end
    return nil
end

local function UpdateCharacter()
    local char = LocalPlayer.Character
    if not char then return nil end

    return {
        Character = char,
        Humanoid = char:FindFirstChildOfClass("Humanoid"),
        RightHand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm"),
        LeftHand = char:FindFirstChild("LeftHand") or char:FindFirstChild("Left Arm"),
        Punch = char:FindFirstChild("Punch") or LocalPlayer.Backpack:FindFirstChild("Punch"),
        HRP = char:FindFirstChild("HumanoidRootPart")
    }
end

