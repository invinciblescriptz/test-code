-- Improved Server Hop
local function ServerHop()
    local placeId = game.PlaceId
    local myJobId = game.JobId
    for attempt = 1, 6 do
        local success, response = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(
                "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"
            ))
        end)
        if not success or not response or not response.data then
            task.wait(2 + attempt)
            continue
        end
        local candidates = {}
        for _, srv in response.data do
            if srv.id == myJobId then continue end
            if srv.playing >= srv.maxPlayers then continue end
            if srv.playing < 8 then continue end
            local fill = srv.playing / srv.maxPlayers
            if fill > 0.25 and fill < 0.9 then
                table.insert(candidates, srv)
            end
        end
        if #candidates == 0 then
            task.wait(3 + attempt * 1.5)
            continue
        end
        local target = candidates[math.random(1, #candidates)]
        pcall(function()
            TeleportService:TeleportToPlaceInstance(placeId, target.id, LocalPlayer)
        end)
        task.wait(5 + attempt * 2)
    end
    warn("Server hop exhausted attempts")
end

-- Main Loop
RunService.Heartbeat:Connect(function()
    -- Server Hop
    if AutoServerHopEnabled and (os.clock() - LastServerHop) >= ServerHopInterval then
        LastServerHop = os.clock()
        task.spawn(ServerHop)
    end

    -- Sunset refresh
    if AutoSetSunsetEnabled and math.floor(os.clock()) % 5 == 0 then
        setSunsetTime()
    end

    -- Hitbox refresh
    if AutoBigHitboxEnabled and math.floor(os.clock() * 10) % 3 == 0 then
        setBigHitbox()
    end

    -- Aggressive position lock
    if AutoLockPositionEnabled and HRP then
        if positionLockAlignPos then
            positionLockAlignPos.Position = gymPos
        end
        if math.floor(os.clock() * 20) % 3 == 0 then
            HRP.CFrame = CFrame.new(gymPos) * HRP.CFrame.Rotation
        end
    end

    UpdateAll()
    if not Character or not Humanoid or Humanoid.Health <= 0 then return end

    -- Equip Punch
    if not Punch then
        local tool = LocalPlayer.Backpack:FindFirstChild("Punch")
        if tool then Humanoid:EquipTool(tool) end
        return
    end

    -- Auto Punch
    if AutoFarmEnabled and (os.clock() - LastAttack) >= 0.07 then
        LastAttack = os.clock()
        local attackTime = Punch:FindFirstChild("attackTime")
        if attackTime then attackTime.Value = 0 end
        Punch:Activate()
    end

    -- Auto Good Karma: ONLY target evil players
    if AutoGoodKarmaEnabled then
        for _, target in ipairs(Players:GetPlayers()) do
            if target == LocalPlayer then continue end
            local evilKarma = target:FindFirstChild("evilKarma")
            local goodKarma = target:FindFirstChild("goodKarma")
            if not (evilKarma and goodKarma and evilKarma:IsA("IntValue") and goodKarma:IsA("IntValue")) then continue end
            if evilKarma.Value <= goodKarma.Value then continue end -- Skip if not evil

            local tChar = target.Character
            if not tChar then continue end
            local tHRP = tChar:FindFirstChild("HumanoidRootPart")
            local tHead = tChar:FindFirstChild("Head")
            local tHum = tChar:FindFirstChildOfClass("Humanoid")

            if tHum and tHum.Health > 0 and (tHRP or tHead) then
                local hand = Character:FindFirstChild("RightHand") or Character:FindFirstChild("LeftHand") or Character:FindFirstChild("Left Arm")
                if hand then
                    -- Touch RootPart
                    if tHRP then
                        firetouchinterest(hand, tHRP, 0)
                        task.wait()
                        firetouchinterest(hand, tHRP, 1)
                    end
                    -- Touch Head (better kill registration)
                    if tHead then
                        firetouchinterest(hand, tHead, 0)
                        task.wait()
                        firetouchinterest(hand, tHead, 1)
                    end
                end
            end
        end
    end
end)

