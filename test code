-- Server Hop Function
local function ServerHop()
    local placeId = game.PlaceId
    local myJobId = game.JobId

    for attempt = 1, 6 do
        local success, response = pcall(function()
            return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"))
        end)

        if not success or not response or not response.data then
            task.wait(2 + attempt)
            continue
        end

        local candidates = {}
        for _, srv in ipairs(response.data) do
            if srv.id == myJobId then continue end
            if srv.playing >= srv.maxPlayers then continue end
            if srv.playing < 8 then continue end
            local fill = srv.playing / srv.maxPlayers
            if fill > 0.25 and fill < 0.9 then
                table.insert(candidates, srv)
            end
        end

        if #candidates == 0 then
            task.wait(3 + attempt * 1.5)
            continue
        end

        local target = candidates[math.random(1, #candidates)]
        pcall(function()
            TeleportService:TeleportToPlaceInstance(placeId, target.id, LocalPlayer)
        end)

        task.wait(5 + attempt * 2)
    end
    warn("Server hop exhausted attempts")
end

-- Main Loop
RunService.Heartbeat:Connect(function()
    -- Server Hop
    if autoServerHop and (os.clock() - LastServerHop) >= serverHopInterval then
        LastServerHop = os.clock()
        task.spawn(ServerHop)
    end

    -- Auto Night Time
    if autoSetNight and math.floor(os.clock()) % 5 == 0 then
        setNightTime()
    end

    -- Auto Big Hitbox
    if autoBigHitbox and math.floor(os.clock() * 10) % 3 == 0 then
        setBigHitbox()
    end

    -- Auto Lock Position
    if autoLockPosition and HRP then
        if positionLockAlignPos then
            positionLockAlignPos.Position = gymPos
        end
        if math.floor(os.clock() * 20) % 3 == 0 then
            HRP.CFrame = CFrame.new(gymPos) * HRP.CFrame.Rotation
        end
    end

    UpdateAll()

    if not autoFarm or not Character or not Humanoid or Humanoid.Health <= 0 then return end
    if not Punch then
        local tool = LocalPlayer.Backpack:FindFirstChild("Punch")
        if tool then Humanoid:EquipTool(tool) end
        return
    end

    if (os.clock() - LastAttack) < 0.08 then return end
    LastAttack = os.clock()

    -- Attack
    local attackTime = Punch:FindFirstChild("attackTime")
    if attackTime then attackTime.Value = 0 end
    Punch:Activate()

    for _, other in ipairs(Players:GetPlayers()) do
        if other == LocalPlayer then continue end
        if not ShouldKillPlayer(other) then continue end

        local char = other.Character
        if not char then continue end

        local hum = char:FindFirstChildOfClass("Humanoid")
        local head = char:FindFirstChild("Head")
        local root = char:FindFirstChild("HumanoidRootPart")

        if hum and head and root and hum.Health > 0 and Hand then
            local wasAnchored = root.Anchored
            root.Anchored = true
            firetouchinterest(head, Hand, 0)
            task.wait()
            firetouchinterest(head, Hand, 1)
            root.Anchored = wasAnchored
        end
    end
end)

