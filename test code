local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local lockConn = nil
local isLocked = false
local storedCFrame = nil

local function getHRP()
    if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        return player.Character.HumanoidRootPart
    end
    return nil
end

local function setPositionLock(en)
    local hrp = getHRP()
    if not hrp then return end

    if en then
        -- Store current position
        storedCFrame = hrp.CFrame
        hrp.Anchored = true
        -- Disconnect previous connection if exists
        if lockConn then
            lockConn:Disconnect()
        end
        -- Connect to Heartbeat to keep position
        lockConn = RunService.Heartbeat:Connect(function()
            local r = getHRP()
            if r then
                r.CFrame = storedCFrame
            end
        end)
        isLocked = true
    else
        if hrp then
            hrp.Anchored = false
        end
        if lockConn then
            lockConn:Disconnect()
            lockConn = nil
        end
        isLocked = false
    end
end

rebirthTab:AddButton("Lock Position", function()
    setPositionLock(not isLocked)
end)

