-- Karma Counter Logic
local evilKarma = 0

local function updateDisplay()
    karmaLabel.Text = tostring(evilKarma)
    local intensity = math.min(1, evilKarma / 10000)
    karmaLabel.TextColor3 = Color3.fromRGB(255, 60 + (195 * (1 - intensity)), 60)
end

plusButton.MouseButton1Click:Connect(function()
    evilKarma = evilKarma + 1
    updateDisplay()
end)

minusButton.MouseButton1Click:Connect(function()
    if evilKarma > 0 then
        evilKarma = evilKarma - 1
        updateDisplay()
    end
end)

resetButton.MouseButton1Click:Connect(function()
    evilKarma = 0
    updateDisplay()
end)

-- Shortcut: Press E to +1
game:GetService("UserInputService").InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.E then
        evilKarma = evilKarma + 1
        updateDisplay()
    end
end)

