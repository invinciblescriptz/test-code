-- Remove punch animation
local function removePunchAnimation()
    local function stopAnimTracks(humanoid)
        for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
            if track.Animation then
                local id = track.Animation.AnimationId
                local name = track.Name:lower()
                if id == "rbxassetid://3638729053" or id == "rbxassetid://3638767427" or name:match("punch") or name:match("attack") or name:match("right") then
                    track:Stop()
                end
            end
        end
    end
    local function setupHumanoid(humanoid)
        humanoid.AnimationPlayed:Connect(function(track)
            stopAnimTracks(humanoid)
        end)
        for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
            if track.Animation then
                local id = track.Animation.AnimationId
                local name = track.Name:lower()
                if id == "rbxassetid://3638729053" or id == "rbxassetid://3638767427" or name:match("punch") or name:match("attack") or name:match("right") then
                    track:Stop()
                end
            end
        end
    end
    local function overrideTool(tool)
        if not (tool and (tool.Name == "Punch" or tool.Name:match("Attack") or tool.Name:match("Right"))) then return end
        if not tool:GetAttribute("ActivatedOverride") then
            tool:SetAttribute("ActivatedOverride", true)
            local conn = tool.Activated:Connect(function()
                wait(0.05)
                local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
                if humanoid then
                    for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
                        if track.Animation then
                            local id = track.Animation.AnimationId
                            local name = track.Name:lower()
                            if id == "rbxassetid://3638729053" or id == "rbxassetid://3638767427" or name:match("punch") or name:match("attack") or name:match("right") then
                                track:Stop()
                            end
                        end
                    end
                end
            end)
            if not _G.ToolConnections then _G.ToolConnections = {} end
            _G.ToolConnections[tool] = conn
        end
    end
    -- Existing tools
    for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
        overrideTool(tool)
    end
    for _, tool in pairs(LocalPlayer.Character:GetChildren()) do
        overrideTool(tool)
    end
    -- Future tools
    if not _G.BackpackAddedConnection then
        _G.BackpackAddedConnection = LocalPlayer.Backpack.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                wait(0.1)
                overrideTool(child)
            end
        end)
    end
    if not _G.CharacterChildAdded then
        _G.CharacterChildAdded = LocalPlayer.Character.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then
                wait(0.1)
                overrideTool(child)
            end
        end)
    end
    -- Animation monitor
    if not _G.AnimMonitorConnection then
        _G.AnimMonitorConnection = RunService.Heartbeat:Connect(function()
            if tick() % 0.5 < 0.01 then
                local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
                if humanoid then
                    stopAnimTracks(humanoid)
                end
            end
        end)
    end
    -- Character respawn
    if not _G.CharacterAdded then
        _G.CharacterAdded = LocalPlayer.CharacterAdded:Connect(function(newChar)
            wait(1)
            setupHumanoid(newChar:FindFirstChildOfClass("Humanoid"))
            for _, tool in pairs(newChar:GetChildren()) do
                if tool:IsA("Tool") then overrideTool(tool) end
            end
        end)
    end
end
removePunchAnimation()

