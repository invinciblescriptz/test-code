local function createButton(text, y)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0, 300, 0, 40)
    btn.Position = UDim2.new(0, 20, 0, y)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Buttons are now red
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 16
    return btn
end

local function createToggleButton(text, y, initialState)
    local btn = createButton(text, y)
    local state = initialState
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = text:gsub(": .+$", ": " .. (state and "ON" or "OFF"))
        return state
    end)
    -- Initialize text
    btn.Text = text:gsub(": .+$", ": " .. (initialState and "ON" or "OFF"))
    return btn, function() return state end
end

local function createSlider(text, y, min, max, initial)
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(0, 150, 0, 20)
    label.Position = UDim2.new(0, 20, 0, y)
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.SourceSans
    label.TextSize = 14

    local sliderBtn = createButton(initial, y + 20)
    local values = {min, max}
    local currentIdx = 1
    sliderBtn.MouseButton1Click:Connect(function()
        -- cycle through preset values
        local options = {min, max, math.floor((min+max)/2)}
        currentIdx = currentIdx + 1
        if currentIdx > #options then currentIdx = 1 end
        sliderBtn.Text = tostring(options[currentIdx])
        return options[currentIdx]
    end)
    sliderBtn.Text = tostring(initial)
    return label, function() return tonumber(sliderBtn.Text) end
end

