        storedCFrame = hrp.CFrame
        hrp.Anchored = true
        -- Disconnect previous connection if exists
        if lockConn then
            lockConn:Disconnect()
        end
        -- Connect to Heartbeat to keep position
        lockConn = RunService.Heartbeat:Connect(function()
            local r = getHRP()
            if r then
                r.CFrame = storedCFrame
            end
        end)
        isLocked = true
    else
        if hrp then
            hrp.Anchored = false
        end
        if lockConn then
            lockConn:Disconnect()
            lockConn = nil
        end
        isLocked = false
    end
end

