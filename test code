-- Helper Functions
local function getHumanoidRootPart()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function teleportTo(position)
    local hrp = getHumanoidRootPart()
    if hrp then
        hrp.CFrame = CFrame.new(position)
    end
end

local function safeEquip(toolName)
    pcall(function()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("Humanoid") then return end
        local tool = LocalPlayer.Backpack:FindFirstChild(toolName) or char:FindFirstChild(toolName)
        if tool and tool.Parent ~= char then
            char.Humanoid:EquipTool(tool)
        end
    end)
end

-- Automatic Repetition (Pushups, Weights, Handstands)
local function startAutoRep(toolName, key)
    task.spawn(function()
        while states[key] and getgenv().NexusRunning do
            pcall(function()
                local char = LocalPlayer.Character
                local humanoid = char and char:FindFirstChildOfClass("Humanoid")
                if not humanoid or humanoid.Health <= 0 then task.wait(2) return end
                safeEquip(toolName)
                muscleEvent:FireServer("rep")
            end)
            task.wait(0.1)
        end
        -- Cleanup: unequip tool
        pcall(function()
            local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(toolName)
            if tool then
                tool.Parent = LocalPlayer.Backpack
            end
        end)
    end)
end

