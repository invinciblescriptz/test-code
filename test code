-- =======================
-- Position Lock Functions
-- =======================
local function clearPositionLock()
    if positionLockAlignPos then
        positionLockAlignPos:Destroy()
        positionLockAlignPos = nil
    end
    if positionLockAttachment then
        positionLockAttachment:Destroy()
        positionLockAttachment = nil
    end
end

local function setupPositionLock()
    clearPositionLock()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    pcall(function() hrp:SetNetworkOwner(LocalPlayer) end)

    positionLockAttachment = Instance.new("Attachment")
    positionLockAttachment.Parent = hrp

    positionLockAlignPos = Instance.new("AlignPosition")
    positionLockAlignPos.Attachment0 = positionLockAttachment
    positionLockAlignPos.Position = gymPos
    positionLockAlignPos.MaxForce = 1e7
    positionLockAlignPos.MaxVelocity = math.huge
    positionLockAlignPos.Responsiveness = 200
    positionLockAlignPos.RigidityEnabled = true
    positionLockAlignPos.Parent = hrp
end

