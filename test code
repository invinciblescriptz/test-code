spawn(function()
    local blockedAnimations = {
        ["rbxassetid://3638729053"] = true,
        ["rbxassetid://3638767427"] = true,
    }

    local function setupAnimationBlocking()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("Humanoid") then return end

        local humanoid = char.Humanoid

        for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
            if track.Animation then
                local animId = track.Animation.AnimationId
                local name = track.Name:lower()
                if blockedAnimations[animId] or name:match("punch") or name:match("attack") or name:match("right") then
                    track:Stop()
                end
            end
        end
    end

    -- Monitor animations
    if not _G.AnimMonitorConnection then
        _G.AnimMonitorConnection = RunService.Heartbeat:Connect(function()
            if tick() % 0.5 < 0.01 then
                setupAnimationBlocking()
            end
        end)
    end

    -- Tool override
    local function processTool(tool)
        if not tool or not tool:IsA("Tool") then return end
        if (tool.Name:match("Punch") or tool.Name:match("Attack") or tool.Name:match("Right")) 
            and not tool:GetAttribute("ActivatedOverride") then

            tool:SetAttribute("ActivatedOverride", true)
            tool.Activated:Connect(function()
                task.wait(0.05)
                setupAnimationBlocking()
            end)
        end
    end

    -- Initial setup
    for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
        processTool(tool)
    end

    LocalPlayer.Backpack.ChildAdded:Connect(function(child)
        task.wait(0.1)
        processTool(child)
    end)

    if LocalPlayer.Character then
        for _, child in pairs(LocalPlayer.Character:GetChildren()) do
            processTool(child)
        end
    end

    LocalPlayer.Character.ChildAdded:Connect(function(child)
        task.wait(0.1)
        processTool(child)
    end)
end)

