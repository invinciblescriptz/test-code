tabRebirth:AddSwitch("Fast Rebirth Pack Farm", function(v)
    getgenv().FastPackFarm = v
    if v then
        task.spawn(function()
            local rep = RS.rEvents
            local pets = LocalPlayer:WaitForChild("petsFolder")
            local leader = LocalPlayer:WaitForChild("leaderstats")

            local function equipAllPets()
                for _, folder in ipairs(pets:GetChildren()) do
                    if folder:IsA("Folder") then
                        for _, pet in ipairs(folder:GetChildren()) do
                            rep.equipPetEvent:FireServer("equipPet", pet)
                        end
                    end
                end
            end

            while getgenv().FastPackFarm do
                pcall(function()
                    -- Equip all pets
                    equipAllPets()
                    task.wait(0.2)

                    -- Calculate need based on rebirths
                    local need = 10000 + 5000 * leader.Rebirths.Value
                    if LocalPlayer.ultimatesFolder:FindFirstChild("Golden Rebirth") then
                        need = math.floor(need * (1 - LocalPlayer.ultimatesFolder["Golden Rebirth"].Value * 0.1))
                    end

                    -- Equip best pet fallback
                    local bestPet = pets.Unique:FindFirstChild("Swift Samurai") or pets.Unique:FindFirstChildWhichIsA("Instance")
                    if bestPet then
                        rep.equipPetEvent:FireServer("equipPet", bestPet)
                    end

                    -- Sit on Jungle Bar Lift
                    local bar = Workspace.machinesFolder and Workspace.machinesFolder:FindFirstChild("Jungle Bar Lift")
                    if bar and bar:FindFirstChild("interactSeat") and getHumanoidRootPart() then
                        getHumanoidRootPart().CFrame = bar.interactSeat.CFrame * CFrame.new(0, 4, 0)
                        task.wait(0.4)
                    end

                    local oldRebirth = leader.Rebirths.Value
                    repeat
                        RS.rEvents.rebirthRemote:InvokeServer("rebirthRequest")
                        task.wait(0.15)
                    until leader.Rebirths.Value > oldRebirth or not getgenv().FastPackFarm
                end)
                task.wait(0.6)
            end
        end)
    end
end)

