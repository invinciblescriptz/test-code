-- Variables for position lock
local positionLockAlignPos, positionLockAttachment

function clearPositionLock()
    if positionLockAlignPos then positionLockAlignPos:Destroy() positionLockAlignPos = nil end
    if positionLockAttachment then positionLockAttachment:Destroy() positionLockAttachment = nil end
end

function setupPositionLock()
    clearPositionLock()
    local hrp = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    pcall(function() hrp:SetNetworkOwner(LocalPlayer) end)
    positionLockAttachment = Instance.new("Attachment", hrp)
    positionLockAlignPos = Instance.new("AlignPosition")
    positionLockAlignPos.Attachment0 = positionLockAttachment
    positionLockAlignPos.Position = gymCFrame.Position
    positionLockAlignPos.MaxForce = 1e7
    positionLockAlignPos.MaxVelocity = math.huge
    positionLockAlignPos.Responsiveness = 200
    positionLockAlignPos.RigidityEnabled = true
    positionLockAlignPos.Parent = hrp
end

